{
  "name": "littlecolorbook",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @littlecolorbook/web",
    "dev:web": "npm run dev --workspace @littlecolorbook/web",
    "dev:worker": "npm run dev --workspace @littlecolorbook/worker",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "check": "npm run typecheck && npm run build && npm run test:smoke",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.1",
    "next": "^16.2.2",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.365.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "drizzle-kit": "^0.31.10"
  }
}
