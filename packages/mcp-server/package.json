{
  "name": "@littlecolorbook/mcp-server",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "description": "MCP server that exposes the LCB Phase 4 agent control plane as Claude Desktop tools",
  "main": "./dist/index.js",
  "bin": {
    "lcb-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
