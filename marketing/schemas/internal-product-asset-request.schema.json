{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://littlecolorbook.com/schemas/internal-product-asset-request.schema.json",
  "title": "Internal Product Asset Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "source_asset_ids",
    "order_style",
    "offer_id",
    "page_count_offer",
    "output_formats",
    "aspect_ratios"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "source_asset_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "order_style": {
      "type": "string",
      "enum": [
        "sample",
        "pdf_preview",
        "print_mockup",
        "bundle_mockup",
        "proof_pair",
        "book_preview",
        "cover_variant",
        "proof_video"
      ]
    },
    "offer_id": {
      "type": "string",
      "enum": [
        "sample-free",
        "pdf-30",
        "pdf-50",
        "pdf-100",
        "print-30",
        "print-50",
        "print-100"
      ]
    },
    "page_count_offer": {
      "type": "integer",
      "minimum": 1
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["pdf", "print"]
    },
    "bundle_offer": {
      "type": "string",
      "enum": ["none", "solo", "sibling_set", "sibling_trio", "custom"],
      "default": "none"
    },
    "child_first_name": {
      "type": ["string", "null"],
      "maxLength": 80
    },
    "occasion": {
      "type": ["string", "null"],
      "maxLength": 80
    },
    "output_formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["png", "jpeg", "webp", "mp4"]
      },
      "uniqueItems": true
    },
    "aspect_ratios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["9:16", "4:5", "1:1", "3:4", "16:9"]
      },
      "uniqueItems": true
    },
    "notes": {
      "type": ["string", "null"],
      "maxLength": 1000
    }
  }
}
